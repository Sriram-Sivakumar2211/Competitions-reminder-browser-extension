{
  "manifest_version": 3,
  "name": "HackTrack",
  "version": "1.0.0",
  "description": "Save and track hackathons, competitions, and contests with dates, countdowns, and reminders.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HackTrack"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
